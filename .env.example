# Required Lemon Squeezy public checkout configuration
NEXT_PUBLIC_LEMON_SQUEEZY_STORE_ID=
NEXT_PUBLIC_LEMON_SQUEEZY_PRODUCT_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=

# Required database
DATABASE_URL=postgresql://user:password@localhost:5432/deploy_health_scanner

# Optional cookie signing secret (recommended in production)
COOKIE_SIGNING_SECRET=

# Optional cron protection (send as Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Optional SMTP email alerts
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@deployhealthscanner.com
ALERT_FROM_EMAIL=alerts@deployhealthscanner.com
